{
    "name": "keyteki",
    "version": "2.0.0",
    "description": "A Keyforge Card Game Server",
    "main": "index.js",
    "engines": {
        "node": ">=22.12.0 <25"
    },
    "scripts": {
        "mongod": "mongod --dbpath=/data --port 27017\n",
        "start": "node .",
        "dev:lobby": "NODE_APP_INSTANCE=node nodemon --inspect=0.0.0.0:9229 .",
        "dev:gamenode": "NODE_APP_INSTANCE=node nodemon --inspect=0.0.0.0:9229 server/gamenode",
        "fetchdata": "node server/scripts/fetchdata",
        "game": "node server/gamenode",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint --ext=js --ext=jsx client/ server/ test/",
        "build": "vite build --config vite.config.mjs",
        "typecheck:client": "tsc -p client/tsconfig.json --noEmit",
        "lint:js": "eslint . --ext .js,.jsx,.ts,.tsx",
        "lint:js:fix": "npm run lint:js -- --fix"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ]
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/keyteki/keyteki.git"
    },
    "keywords": [
        "keyforge",
        "cardgame"
    ],
    "author": "Various",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/keyteki/keyteki/issues"
    },
    "homepage": "https://github.com/keyteki/keyteki#readme",
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.2.0",
        "@hcaptcha/react-hcaptcha": "^2.0.2",
        "@heroui/react": "^3.0.0-beta.8",
        "@heroui/styles": "^3.0.0-beta.8",
        "@popperjs/core": "^2.11.8",
        "@reduxjs/toolkit": "^2.2.3",
        "@sendgrid/mail": "^8.1.6",
        "@sentry/node": "^10.39.0",
        "@sentry/react": "^10.39.0",
        "@tailwindcss/postcss": "^4.2.0",
        "bcrypt": "^6.0.0",
        "buffer": "^6.0.3",
        "canvas": "^3.0.0",
        "circletype": "^2.3.0",
        "clipboard": "^2.0.6",
        "config": "^3.3.12",
        "cookie-parser": "^1.4.5",
        "core-js": "^3.6.4",
        "emoji-js": "^3.5.0",
        "eslint-config-prettier": "^6.11.0",
        "eslint-plugin-prettier": "^3.1.3",
        "event-source-polyfill": "^1.0.12",
        "express": "^4.19.2",
        "fabric": "^5.5.2",
        "formik": "^2.1.4",
        "helmet": "^3.22.0",
        "husky": "^4.3.8",
        "i18next": "^17.3.1",
        "i18next-browser-languagedetector": "^3.1.1",
        "jsondiffpatch": "^0.4.1",
        "jsonwebtoken": "^9.0.0",
        "lint-staged": "^10.2.4",
        "lodash.debounce": "^4.0.8",
        "moment": "^2.29.4",
        "monk": "^7.1.2",
        "node-noop": "^1.0.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.0",
        "passport-local": "^1.0.0",
        "path-browserify": "^1.0.1",
        "patreon": "^0.4.1",
        "pg": "^8.8.0",
        "prettier": "^2.0.5",
        "process": "^0.11.10",
        "prop-types": "^15.6.0",
        "qrcode": "^1.4.4",
        "query-string-es5": "^6.1.4",
        "react": "^19.2.4",
        "react-clipboardjs-copy": "^2.1.0",
        "react-dnd": "^16.0.1",
        "react-dnd-touch-backend": "^16.0.1",
        "react-dom": "^19.2.4",
        "react-draggable": "^4.5.0",
        "react-i18next": "^10.13.2",
        "react-redux": "^9.2.0",
        "react-responsive-carousel": "^3.2.18",
        "react-router-dom": "^6.22.3",
        "react-select": "^5.10.2",
        "react-transition-group": "^4.4.5",
        "redis": "^5.11.0",
        "redux": "^5.0.1",
        "regenerator-runtime": "^0.14.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "stream-browserify": "^3.0.0",
        "tailwindcss": "^4.2.0",
        "underscore": "^1.13.8",
        "url": "^0.11.4",
        "util": "^0.12.5",
        "winston": "^3.2.1",
        "yup": "^0.29.0"
    },
    "overrides": {
        "@sentry/node": {
            "minimatch": "^10.2.2"
        },
        "glob@^10.5.0": {
            "minimatch": "^10.2.2"
        }
    },
    "devDependencies": {
        "@sentry/vite-plugin": "^4.9.1",
        "@types/node": "^22.19.11",
        "@vitejs/plugin-react": "^5.1.4",
        "autoprefixer": "^10.4.16",
        "body-parser": "^1.18.2",
        "command-line-args": "^6.0.1",
        "ejs": "^3.1.10",
        "eslint": "^7.1.0",
        "eslint-plugin-react": "^7.20.0",
        "eslint-plugin-react-hooks": "^4.0.4",
        "handlebars": "^4.7.9",
        "nodemon": "^3.1.13",
        "nunjucks": "^3.2.2",
        "pegjs": "^0.10.0",
        "precss": "^4.0.0",
        "typescript": "^5.4.5",
        "vite": "^7.3.2",
        "vitest": "4.0.18"
    }
}
